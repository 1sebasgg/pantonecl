{
  "version": 2,
  "framework": null,
  "outputDirectory": ".output/public",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/_nitro/(.)",
      "dest": "/_nitro/$1"
    },
    {
      "src": "/api/(.)",
      "dest": "/.output/server/index.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/.output/server/index.mjs"
    }
  ]
}
